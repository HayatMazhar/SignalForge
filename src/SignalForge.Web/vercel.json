{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://signalforge-api.onrender.com/api/:path*" },
    { "source": "/hubs/:path*", "destination": "https://signalforge-api.onrender.com/hubs/:path*" }
  ]
}
