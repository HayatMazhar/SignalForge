{
  "expo": {
    "name": "SignalForge",
    "slug": "signalforge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "signalforge",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06060B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.signalforge.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#06060B"
      },
      "package": "com.signalforge.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00FF94"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "71d6571e-0488-41f1-b360-3cfe99f88b76"
      }
    },
    "owner": "mazhar1785"
  }
}
